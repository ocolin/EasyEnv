{
    "name": "ocolin/easyenv",
    "description": "Very simple tool to load env variables from file",
    "type": "library",
    "license": "MIT",
    "keywords": ["env", "environment", "dotenv", "config"],
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.1",
        "mikey179/vfsstream": "^1.6"
    },
    "prefer-stable" : true,
    "autoload": {
        "psr-4": {
            "Ocolin\\EasyEnv\\": "src/"
        }
    },
    "autoload-dev": {
      "psr-4": {
        "Ocolin\\EasyEnv\\Tests\\": "tests/"
      }
    },
    "authors": [
        {
            "name": "Colin Miller",
            "email": "ocolin@cruzio.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
      "php": ">=8.3"
    },
    "scripts": {
        "test": "vendor/bin/phpunit --no-coverage --display-deprecations --display-notices",
        "test-coverage": "XDEBUG_MODE=coverage vendor/bin/phpunit --coverage-html coverage"
    }
}
